# Supabase staging does not need the legacy backend switches below.
PORT=3000

# Required only when the local Express teacher login is used.
SESSION_SECRET=replace-with-at-least-32-random-characters
TEACHER_PASSWORD=replace-with-a-strong-local-password

# Legacy compatibility is opt-in. Keep both false for Supabase/GitHub Pages.
ENABLE_LEGACY_REALTIME=false
ENABLE_LEGACY_GAS_PROXY=false
GAS_ENDPOINT=
